{
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "apiex_chat",
        "description": "Send a chat completion request through Apiex. Routes to the best available AI model based on the model tag.",
        "parameters": {
          "type": "object",
          "required": ["model", "messages"],
          "properties": {
            "model": {
              "type": "string",
              "description": "Model routing tag (e.g. apex-smart, apex-cheap)"
            },
            "messages": {
              "type": "array",
              "description": "Chat messages in OpenAI format",
              "items": {
                "type": "object",
                "required": ["role", "content"],
                "properties": {
                  "role": {
                    "type": "string",
                    "enum": ["system", "user", "assistant"]
                  },
                  "content": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "apiex_models",
        "description": "List available models on Apiex.",
        "parameters": {
          "type": "object",
          "properties": {}
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "apiex_usage",
        "description": "Get usage summary from Apiex.",
        "parameters": {
          "type": "object",
          "properties": {
            "period": {
              "type": "string",
              "description": "Usage period filter (24h, 7d, 30d, all)",
              "enum": ["24h", "7d", "30d", "all"]
            }
          }
        }
      }
    }
  ]
}
