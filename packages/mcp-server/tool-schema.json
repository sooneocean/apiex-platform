{
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "apiex_chat",
        "description": "Send a chat completion request through Apiex. Routes to the best available AI model based on the model tag.",
        "parameters": {
          "type": "object",
          "properties": {
            "model": {
              "type": "string",
              "enum": ["apex-smart", "apex-cheap"],
              "description": "Model routing tag"
            },
            "messages": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "role": { "type": "string" },
                  "content": { "type": "string" }
                },
                "required": ["role", "content"]
              },
              "description": "Chat messages"
            },
            "temperature": {
              "type": "number",
              "minimum": 0,
              "maximum": 2
            },
            "max_tokens": {
              "type": "integer",
              "minimum": 1
            }
          },
          "required": ["model", "messages"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "apiex_models",
        "description": "List available models on Apiex.",
        "parameters": {
          "type": "object",
          "properties": {},
          "required": []
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "apiex_usage",
        "description": "Get usage summary from Apiex.",
        "parameters": {
          "type": "object",
          "properties": {
            "period": {
              "type": "string",
              "description": "Usage period filter (e.g. '7d', '30d')"
            }
          },
          "required": []
        }
      }
    }
  ]
}
